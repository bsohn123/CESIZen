{% set active_route = active_route|default('') %}
{% set menus = menus|default([]) %}

<nav class="topbar" aria-label="Menu principal">
    <a class="topbar-brand" href="{{ path('app_home') }}">CESIZen</a>

    <div class="topbar-nav">
        <a class="topbar-link{{ active_route == 'app_home' ? ' is-active' : '' }}" href="{{ path('app_home') }}"{% if active_route == 'app_home' %} aria-current="page"{% endif %}>Accueil</a>
        <a class="topbar-link{{ active_route == 'app_breathing_guided' ? ' is-active' : '' }}" href="{{ path('app_breathing_guided') }}"{% if active_route == 'app_breathing_guided' %} aria-current="page"{% endif %}>Respiration guid&eacute;e</a>
        <a class="topbar-link{{ active_route == 'app_personal_tracking' ? ' is-active' : '' }}" href="{{ app.user ? path('app_personal_tracking') : path('app_login') }}"{% if active_route == 'app_personal_tracking' %} aria-current="page"{% endif %}>Suivi personnel</a>

        {% for menu in menus %}
            {% set pages = menu.pages %}
            {% if pages|length > 0 %}
                <div class="menu-group">
                    <button class="topbar-link menu-trigger" type="button" aria-haspopup="true">
                        <span>{{ menu.title }}</span>
                        <span class="menu-chevron">&#9662;</span>
                    </button>
                    <div class="menu-dropdown" role="menu" aria-label="Pages de {{ menu.title }}">
                        {% for page in pages %}
                            <a class="menu-page-link" href="{{ path('app_page_show', { slug: page.slug }) }}">{{ page.title }}</a>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        {% endfor %}

        {% if app.user %}
            <div class="user-menu">
                <button
                    type="button"
                    id="user-menu-trigger"
                    class="topbar-link user-trigger"
                    aria-haspopup="menu"
                    aria-expanded="false"
                    aria-controls="user-menu-dropdown"
                >
                    <span class="user-avatar">{{ app.user.userIdentifier|default('U')|slice(0,1)|upper }}</span>
                    <span>Compte</span>
                    <span class="user-chevron">&#9662;</span>
                </button>
                <div id="user-menu-dropdown" class="user-dropdown" role="menu" aria-label="Menu compte">
                    <a class="user-item" href="{{ path('app_profile') }}" role="menuitem">Mon profil</a>
                    <a class="user-item logout" href="{{ path('app_logout') }}" role="menuitem">D&eacute;connexion</a>
                </div>
            </div>
        {% else %}
            <a class="topbar-link topbar-link-soft" href="{{ path('app_login') }}">Se connecter</a>
            <a class="topbar-link topbar-link-primary" href="{{ path('app_register') }}">Cr&eacute;er un compte</a>
        {% endif %}
    </div>
</nav>
