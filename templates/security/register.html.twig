{% extends 'base.html.twig' %}

{% block title %}Inscription | CESIZen{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/auth-register.css') }}">
{% endblock %}

{% block body %}
    <section class="site-shell">
        {% include 'partials/_site_nav.html.twig' %}

        <div class="shell">
            <aside class="aside">
            <div class="aside-intro">
                <div class="brand">CESIZen</div>
                <h2 class="aside-title">Création de compte</h2>
                <p class="aside-copy">
                    Crée ton espace personnel pour suivre ton parcours bien-être.
                </p>
                <p class="aside-quote">"Respire. Chaque inspiration t'ancre, chaque expiration t'apaise."</p>
            </div>

            <div class="aside-visual">
                <img src="{{ asset('images/meditation2.png') }}" alt="Illustration meditation">
            </div>
            </aside>

            <main class="main">
                <div class="card">
                <h1 class="title">Inscription</h1>
                <p class="subtitle">Renseigne les informations pour créer ton compte.</p>

                {% if register_errors is not empty %}
                    <div class="alert alert-danger">
                        <ul>
                            {% for error in register_errors %}
                                <li>{{ error }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                <form method="post">
                    <div class="field">
                        <div class="input-wrap">
                            <span class="input-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none">
                                    <path d="M3 7.5 12 14l9-6.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                    <rect x="3" y="5.5" width="18" height="13" rx="2.5" stroke="currentColor" stroke-width="1.8"/>
                                </svg>
                            </span>
                            <input
                                type="email"
                                id="email"
                                name="email"
                                class="input"
                                autocomplete="email"
                                value="{{ register_email }}"
                                placeholder=" "
                                required
                            >
                            <label class="floating-label" for="email">Email</label>
                        </div>
                    </div>

                    <div class="field">
                        <div class="input-wrap">
                            <span class="input-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none">
                                    <circle cx="12" cy="8" r="3.2" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M5.5 18.5c1.1-3 3.6-4.5 6.5-4.5s5.4 1.5 6.5 4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                </svg>
                            </span>
                            <input
                                type="text"
                                id="username"
                                name="username"
                                class="input"
                                minlength="3"
                                value="{{ register_username }}"
                                placeholder=" "
                                required
                            >
                            <label class="floating-label" for="username">Pseudo</label>
                        </div>
                    </div>

                    <div class="field">
                        <div class="input-wrap">
                            <span class="input-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none">
                                    <rect x="4.5" y="10.5" width="15" height="10" rx="2" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M8 10.5V8a4 4 0 1 1 8 0v2.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                </svg>
                            </span>
                            <input
                                type="password"
                                id="password"
                                name="password"
                                class="input"
                                minlength="8"
                                autocomplete="new-password"
                                placeholder=" "
                                required
                            >
                            <label class="floating-label" for="password">Mot de passe</label>
                        </div>
                    </div>

                    <div class="field">
                        <div class="input-wrap">
                            <span class="input-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none">
                                    <rect x="4.5" y="10.5" width="15" height="10" rx="2" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M8 10.5V8a4 4 0 1 1 8 0v2.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                    <path d="m9.2 15.7 1.8 1.8 3.8-3.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </span>
                            <input
                                type="password"
                                id="password_confirm"
                                name="password_confirm"
                                class="input"
                                minlength="8"
                                autocomplete="new-password"
                                placeholder=" "
                                required
                            >
                            <label class="floating-label" for="password_confirm">Confirmer le mot de passe</label>
                        </div>
                    </div>

                    <div class="consent-field">
                        <label class="consent-label" for="accept_terms">
                            <input
                                type="checkbox"
                                id="accept_terms"
                                name="accept_terms"
                                value="1"
                                class="consent-checkbox"
                                {% if register_accept_terms %}checked{% endif %}
                                required
                            >
                            <span>
                                J'accepte les
                                <a class="consent-link" href="{{ path('app_terms') }}">conditions d'utilisation</a>.
                            </span>
                        </label>
                    </div>

                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('register') }}">

                    <div class="actions">
                        <button type="submit" class="btn-submit">Créer mon compte</button>
                    </div>
                </form>

                <p class="alt-link">
                    Déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a>
                </p>
                </div>
            </main>
        </div>
    </section>
{% endblock %}
