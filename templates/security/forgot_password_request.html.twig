{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublie | CESIZen{% endblock %}

{% block stylesheets %}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

        :root {
            --nature-900: #0f3328;
            --nature-800: #195241;
            --nature-700: #236a54;
            --line: #d6e4dd;
            --text: #1e2a26;
            --muted: #5c6b66;
            --success-bg: #eaf6ef;
            --success-border: #c7e3d1;
            --success-text: #1f5d3a;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Manrope", "Segoe UI", Arial, sans-serif;
            background:
                linear-gradient(160deg, rgba(238, 247, 242, 0.86) 0%, rgba(229, 240, 234, 0.82) 100%),
                url('{{ asset('images/login-bg.jpg') }}') center/cover no-repeat;
            padding: 1.25rem;
            color: var(--text);
        }

        .card {
            width: min(520px, 100%);
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 1.3rem;
            box-shadow: 0 18px 48px rgba(16, 44, 35, 0.12);
        }

        h1 {
            margin: 0;
            color: var(--nature-900);
            font-size: 1.3rem;
            font-weight: 800;
        }

        p {
            margin: 0.4rem 0 1rem;
            color: var(--muted);
            font-size: 0.92rem;
        }

        .alert-success {
            margin: 0 0 0.95rem;
            padding: 0.66rem 0.76rem;
            border-radius: 10px;
            border: 1px solid var(--success-border);
            background: var(--success-bg);
            color: var(--success-text);
            font-size: 0.9rem;
        }

        .field {
            display: grid;
            gap: 0.4rem;
        }

        label {
            font-size: 0.88rem;
            font-weight: 600;
            color: #32423d;
        }

        input {
            width: 100%;
            border: 1px solid #cfded6;
            border-radius: 10px;
            padding: 0.62rem 0.72rem;
            font-size: 0.95rem;
        }

        input:focus {
            outline: none;
            border-color: var(--nature-700);
            box-shadow: 0 0 0 4px rgba(35, 106, 84, 0.14);
        }

        .actions {
            margin-top: 1rem;
            display: flex;
            gap: 0.6rem;
        }

        .btn {
            border-radius: 10px;
            padding: 0.63rem 0.95rem;
            font-size: 0.92rem;
            font-weight: 600;
            text-decoration: none;
            border: 1px solid transparent;
            cursor: pointer;
        }

        .btn-primary {
            background: var(--nature-800);
            border-color: var(--nature-800);
            color: #fff;
        }

        .btn-primary:hover {
            background: #174739;
            border-color: #174739;
        }

        .btn-secondary {
            border-color: #cfddd6;
            color: #355048;
            background: #fff;
        }

        .btn-secondary:hover {
            background: #f6fbf8;
        }
    </style>
{% endblock %}

{% block body %}
    <section class="site-shell site-shell--sm">
        {% include 'partials/_site_nav.html.twig' %}

        <div class="card">
            <h1>Mot de passe oublie</h1>
            <p>Entre ton email pour recevoir un lien de reinitialisation.</p>

            {% for message in app.flashes('success') %}
                <div class="alert-success">{{ message }}</div>
            {% endfor %}

            <form method="post">
                <div class="field">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" autocomplete="email" required>
                </div>

                <div class="actions">
                    <button type="submit" class="btn btn-primary">Envoyer le lien</button>
                    <a class="btn btn-secondary" href="{{ path('app_login') }}">Retour connexion</a>
                </div>
            </form>
        </div>
    </section>
{% endblock %}
