{% extends 'base.html.twig' %}

{% block title %}Connexion | CESIZen{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/auth-login.css') }}">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('scripts/login.js') }}" defer></script>
{% endblock %}

{% block body %}
    <section class="site-shell">
        {% include 'partials/_site_nav.html.twig' %}

        <div class="login-shell">
            <aside class="login-aside">
            <div>
                <div class="brand">CESIZen</div>
                <h2 class="aside-title">Espace utilisateur</h2>
                <p class="aside-copy">
                    Connecte-toi pour accéder a ton espace et gérer ton parcours bien-être.
                </p>
                <div class="aside-highlights">
                    <div class="highlight-item">
                        <span class="highlight-dot"></span>
                        Exercice de respiration guidée
                    </div>
                    <div class="highlight-item">
                        <span class="highlight-dot"></span>
                        Suivi de progression
                    </div>
                    <div class="highlight-item">
                        <span class="highlight-dot"></span>
                        Articles sur le bien-être
                    </div>
                </div>

                <p class="aside-quote">"Un moment pour respirer, un moment pour toi."</p>
            </div>
            </aside>

            <main class="login-main">
                <div class="login-card">
                <h1 class="login-title">Connexion</h1>
                <p class="login-subtitle">Entre ton email et ton mot de passe.</p>

                <form method="post">
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-info">{{ message }}</div>
                    {% endfor %}

                    {% if error_message %}
                        <div class="alert alert-danger">{{ error_message }}</div>
                    {% endif %}

                    {% if app.user %}
                        <div class="alert alert-info">
                            Tu es connecté(e) en tant que {{ app.user.userIdentifier }},
                            <a class="login-link" href="{{ logout_path() }}">se déconnecter</a>.
                        </div>
                    {% endif %}

                    <div class="field">
                        <label for="username">Email</label>
                        <input
                            type="email"
                            value="{{ last_username }}"
                            name="_username"
                            id="username"
                            class="input"
                            autocomplete="email"
                            required
                            autofocus
                        >
                    </div>

                    <div class="field">
                        <label for="password">Mot de passe</label>
                        <div class="password-wrapper">
                            <input
                                type="password"
                                name="_password"
                                id="password"
                                class="input"
                                autocomplete="current-password"
                                required
                            >
                            <button
                                type="button"
                                class="password-toggle"
                                id="password-toggle"
                                data-visible="false"
                                aria-label="Afficher le mot de passe"
                                aria-controls="password"
                            >
                                <svg class="icon-eye" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" stroke="currentColor" stroke-width="1.8"/>
                                    <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8"/>
                                </svg>
                                <svg class="icon-eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M3 3l18 18" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M10.6 10.6a2 2 0 0 0 2.8 2.8" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M9.9 5.2A11.3 11.3 0 0 1 12 5c6.5 0 10 7 10 7a18.7 18.7 0 0 1-3.4 4.3" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M6.2 6.2A18.8 18.8 0 0 0 2 12s3.5 7 10 7c1.5 0 2.8-.3 4-.8" stroke="currentColor" stroke-width="1.8"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="field-meta">
                        <a class="forgot-link" href="{{ path('app_forgot_password_request') }}">Mot de passe oublié ?</a>
                    </div>

                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                    <div class="field" style="margin-top: .2rem;">
                        <label for="_remember_me" style="display:flex; align-items:center; gap:.5rem; cursor:pointer;">
                            <input type="checkbox" name="_remember_me" id="_remember_me">
                            Se souvenir de moi
                        </label>
                    </div>

                    <div class="actions">
                        <button class="btn-submit" type="submit">Se connecter</button>
                    </div>

                    <p class="register-row">
                        Pas encore de compte ?
                        <a class="register-link" href="{{ path('app_register') }}">Creer un compte</a>
                    </p>
                </form>
                </div>
            </main>
        </div>
    </section>
{% endblock %}
