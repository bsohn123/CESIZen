{% extends 'base.html.twig' %}

{% block title %}Connexion | CESIZen{% endblock %}

{% block stylesheets %}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

        :root {
            --nature-900: #0f3328;
            --nature-800: #195241;
            --nature-700: #236a54;
            --nature-100: #e8f2ee;
            --nature-050: #f4faf7;
            --line: #d6e4dd;
            --text: #1e2a26;
            --muted: #5c6b66;
            --danger-bg: #fdf0f0;
            --danger-text: #8a2c2c;
            --danger-border: #f2c7c7;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Manrope", "Segoe UI", Arial, sans-serif;
            color: var(--text);
            background:
                linear-gradient(160deg, rgba(238, 247, 242, 0.86) 0%, rgba(229, 240, 234, 0.82) 100%),
                url('{{ asset('images/login-bg.jpg') }}') center/cover no-repeat;
            display: grid;
            place-items: center;
            padding: 1.25rem;
        }

        .login-shell {
            width: min(980px, 100%);
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 18px 48px rgba(16, 44, 35, 0.12);
            display: grid;
            grid-template-columns: 42% 58%;
        }

        .login-aside {
            padding: 2rem 1.75rem;
            background: linear-gradient(165deg, var(--nature-900), var(--nature-800));
            color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .brand {
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: 0.2px;
        }

        .aside-title {
            margin: 1.5rem 0 0.35rem;
            font-size: 1.25rem;
            font-weight: 700;
        }

        .aside-copy {
            margin: 0;
            line-height: 1.5;
            color: rgba(255, 255, 255, 0.86);
            font-size: 0.95rem;
        }

        .aside-highlights {
            margin-top: 1.25rem;
            display: grid;
            gap: 0.55rem;
        }

        .highlight-item {
            display: flex;
            align-items: center;
            gap: 0.55rem;
            padding: 0.5rem 0.6rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
            background: rgba(255, 255, 255, 0.07);
            border-radius: 10px;
            color: rgba(255, 255, 255, 0.95);
            font-size: 0.9rem;
            font-weight: 600;
        }

        .highlight-dot {
            width: 0.48rem;
            height: 0.48rem;
            border-radius: 999px;
            background: #95d8b3;
            box-shadow: 0 0 0 4px rgba(149, 216, 179, 0.18);
            flex: 0 0 auto;
        }

        .aside-quote {
            margin: 1rem 0 0;
            border-left: 2px solid rgba(255, 255, 255, 0.35);
            padding-left: 0.65rem;
            color: rgba(255, 255, 255, 0.84);
            font-size: 0.9rem;
            line-height: 1.45;
        }

        .login-main {
            padding: 2rem 1.8rem;
            background: var(--nature-050);
        }

        .login-card {
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 1.25rem;
        }

        .login-title {
            margin: 0;
            font-size: 1.28rem;
            color: var(--nature-900);
            font-weight: 800;
            letter-spacing: 0.1px;
        }

        .login-subtitle {
            margin: 0.35rem 0 1.1rem;
            color: var(--muted);
            font-size: 0.92rem;
        }

        .alert {
            margin: 0 0 0.85rem;
            padding: 0.68rem 0.8rem;
            border-radius: 10px;
            border: 1px solid transparent;
            font-size: 0.9rem;
        }

        .alert-danger {
            background: var(--danger-bg);
            color: var(--danger-text);
            border-color: var(--danger-border);
        }

        .alert-info {
            background: var(--nature-100);
            color: var(--nature-900);
            border-color: #c9ddd4;
        }

        .field {
            display: grid;
            gap: 0.38rem;
            margin-bottom: 0.9rem;
        }

        .field label {
            font-size: 0.88rem;
            color: #32423d;
            font-weight: 500;
        }

        .input {
            width: 100%;
            border: 1px solid #cfded6;
            border-radius: 10px;
            background: #fff;
            color: var(--text);
            font-size: 0.95rem;
            padding: 0.62rem 0.72rem;
            outline: none;
            transition: border-color 0.16s ease, box-shadow 0.16s ease;
        }

        .input:focus {
            border-color: var(--nature-700);
            box-shadow: 0 0 0 4px rgba(35, 106, 84, 0.14);
        }

        .password-wrapper {
            position: relative;
        }

        .password-wrapper .input {
            padding-right: 2.8rem;
        }

        .password-toggle {
            position: absolute;
            right: 0.45rem;
            top: 50%;
            transform: translateY(-50%);
            width: 2rem;
            height: 2rem;
            border: 0;
            border-radius: 8px;
            background: transparent;
            color: #456259;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .password-toggle:hover {
            background: #edf5f1;
        }

        .password-toggle:focus-visible {
            outline: 2px solid rgba(35, 106, 84, 0.35);
            outline-offset: 2px;
        }

        .password-toggle .icon-eye-off {
            display: none;
        }

        .password-toggle[data-visible="true"] .icon-eye {
            display: none;
        }

        .password-toggle[data-visible="true"] .icon-eye-off {
            display: block;
        }

        .actions {
            margin-top: 1.1rem;
        }

        .btn-submit {
            width: 100%;
            border: 1px solid var(--nature-800);
            background: var(--nature-800);
            color: #fff;
            border-radius: 10px;
            padding: 0.65rem 0.95rem;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.16s ease, border-color 0.16s ease, transform 0.16s ease;
        }

        .btn-submit:hover {
            background: #174739;
            border-color: #174739;
            transform: translateY(-1px);
        }

        .login-link {
            color: var(--nature-800);
            text-decoration: none;
            font-weight: 600;
        }

        .login-link:hover {
            text-decoration: underline;
        }

        .field-meta {
            display: flex;
            justify-content: flex-end;
            margin-top: -0.25rem;
            margin-bottom: 0.25rem;
        }

        .forgot-link {
            color: var(--nature-800);
            text-decoration: none;
            font-size: 0.86rem;
            font-weight: 600;
        }

        .forgot-link:hover {
            text-decoration: underline;
        }

        .register-row {
            margin: 0.85rem 0 0;
            text-align: center;
            color: var(--muted);
            font-size: 0.9rem;
        }

        .register-link {
            color: var(--nature-800);
            text-decoration: none;
            font-weight: 700;
        }

        .register-link:hover {
            text-decoration: underline;
        }

        @media (max-width: 860px) {
            .login-shell {
                grid-template-columns: 1fr;
            }

            .login-aside {
                padding: 1.25rem 1.25rem 1.4rem;
            }

            .login-main {
                padding: 1.25rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="login-shell">
        <aside class="login-aside">
            <div>
                <div class="brand">CESIZen</div>
                <h2 class="aside-title">Espace utilisateur</h2>
                <p class="aside-copy">
                    Connecte-toi pour accéder a ton espace et gérer ton parcours bien-être.
                </p>
                <div class="aside-highlights">
                    <div class="highlight-item">
                        <span class="highlight-dot"></span>
                        Exercice de respiration guidée
                    </div>
                    <div class="highlight-item">
                        <span class="highlight-dot"></span>
                        Suivi de progression
                    </div>
                    <div class="highlight-item">
                        <span class="highlight-dot"></span>
                        Articles sur le bien-être 
                    </div>
                </div>

                <p class="aside-quote">"Un moment pour respirer, un moment pour toi."</p>
            </div>
        </aside>

        <main class="login-main">
            <div class="login-card">
                <h1 class="login-title">Connexion</h1>
                <p class="login-subtitle">Entre ton email et ton mot de passe.</p>

                <form method="post">
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-info">{{ message }}</div>
                    {% endfor %}

                    {% if error_message %}
                        <div class="alert alert-danger">{{ error_message }}</div>
                    {% endif %}

                    {% if app.user %}
                        <div class="alert alert-info">
                            Tu es connecté(e) en tant que {{ app.user.userIdentifier }},
                            <a class="login-link" href="{{ logout_path() }}">se déconnecter</a>.
                        </div>
                    {% endif %}

                    <div class="field">
                        <label for="username">Email</label>
                        <input
                            type="email"
                            value="{{ last_username }}"
                            name="_username"
                            id="username"
                            class="input"
                            autocomplete="email"
                            required
                            autofocus
                        >
                    </div>

                    <div class="field">
                        <label for="password">Mot de passe</label>
                        <div class="password-wrapper">
                            <input
                                type="password"
                                name="_password"
                                id="password"
                                class="input"
                                autocomplete="current-password"
                                required
                            >
                            <button
                                type="button"
                                class="password-toggle"
                                id="password-toggle"
                                data-visible="false"
                                aria-label="Afficher le mot de passe"
                                aria-controls="password"
                            >
                                <svg class="icon-eye" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" stroke="currentColor" stroke-width="1.8"/>
                                    <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8"/>
                                </svg>
                                <svg class="icon-eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M3 3l18 18" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M10.6 10.6a2 2 0 0 0 2.8 2.8" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M9.9 5.2A11.3 11.3 0 0 1 12 5c6.5 0 10 7 10 7a18.7 18.7 0 0 1-3.4 4.3" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M6.2 6.2A18.8 18.8 0 0 0 2 12s3.5 7 10 7c1.5 0 2.8-.3 4-.8" stroke="currentColor" stroke-width="1.8"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="field-meta">
                        <a class="forgot-link" href="{{ path('app_forgot_password_request') }}">Mot de passe oublié ?</a>
                    </div>

                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
                    
                    <div class="field" style="margin-top: .2rem;">
                        <label for="_remember_me" style="display:flex; align-items:center; gap:.5rem; cursor:pointer;">
                            <input type="checkbox" name="_remember_me" id="_remember_me">
                            Se souvenir de moi
                        </label>
                    </div>

                    <div class="actions">
                        <button class="btn-submit" type="submit">Se connecter</button>
                    </div>

                    <p class="register-row">
                        Pas encore de compte ?
                        <a class="register-link" href="{{ path('app_register') }}">Creer un compte</a>
                    </p>
                </form>
            </div>
        </main>
    </section>

    <script>
        (() => {
            const passwordInput = document.getElementById('password');
            const toggleButton = document.getElementById('password-toggle');

            if (!passwordInput || !toggleButton) {
                return;
            }

            toggleButton.addEventListener('click', () => {
                const isVisible = passwordInput.type === 'text';
                passwordInput.type = isVisible ? 'password' : 'text';
                toggleButton.dataset.visible = isVisible ? 'false' : 'true';
                toggleButton.setAttribute(
                    'aria-label',
                    isVisible ? 'Afficher le mot de passe' : 'Masquer le mot de passe'
                );
            });
        })();
    </script>
{% endblock %}
