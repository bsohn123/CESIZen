{% extends 'base.html.twig' %}

{% block title %}Connexion | CESIZen{% endblock %}

{% block stylesheets %}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

        :root {
            --nature-900: #0f3328;
            --nature-800: #195241;
            --nature-700: #236a54;
            --nature-100: #e8f2ee;
            --nature-050: #f4faf7;
            --line: #d6e4dd;
            --text: #1e2a26;
            --muted: #5c6b66;
            --danger-bg: #fdf0f0;
            --danger-text: #8a2c2c;
            --danger-border: #f2c7c7;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Manrope", "Segoe UI", Arial, sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at 8% 10%, rgba(25, 82, 65, 0.15) 0, transparent 32%),
                radial-gradient(circle at 92% 90%, rgba(35, 106, 84, 0.12) 0, transparent 30%),
                linear-gradient(160deg, #eef7f2 0%, #e5f0ea 100%);
            display: grid;
            place-items: center;
            padding: 1.25rem;
        }

        .login-shell {
            width: min(980px, 100%);
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 18px 48px rgba(16, 44, 35, 0.12);
            display: grid;
            grid-template-columns: 42% 58%;
        }

        .login-aside {
            padding: 2rem 1.75rem;
            background: linear-gradient(165deg, var(--nature-900), var(--nature-800));
            color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .brand {
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: 0.2px;
        }

        .aside-title {
            margin: 1.5rem 0 0.35rem;
            font-size: 1.25rem;
            font-weight: 700;
        }

        .aside-copy {
            margin: 0;
            line-height: 1.5;
            color: rgba(255, 255, 255, 0.86);
            font-size: 0.95rem;
        }

        .aside-tag {
            margin-top: 2rem;
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.35rem 0.65rem;
            border: 1px solid rgba(255, 255, 255, 0.28);
            border-radius: 999px;
            width: fit-content;
            color: rgba(255, 255, 255, 0.92);
            font-size: 0.82rem;
        }

        .login-main {
            padding: 2rem 1.8rem;
            background: var(--nature-050);
        }

        .login-card {
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 1.25rem;
        }

        .login-title {
            margin: 0;
            font-size: 1.28rem;
            color: var(--nature-900);
            font-weight: 800;
            letter-spacing: 0.1px;
        }

        .login-subtitle {
            margin: 0.35rem 0 1.1rem;
            color: var(--muted);
            font-size: 0.92rem;
        }

        .alert {
            margin: 0 0 0.85rem;
            padding: 0.68rem 0.8rem;
            border-radius: 10px;
            border: 1px solid transparent;
            font-size: 0.9rem;
        }

        .alert-danger {
            background: var(--danger-bg);
            color: var(--danger-text);
            border-color: var(--danger-border);
        }

        .alert-info {
            background: var(--nature-100);
            color: var(--nature-900);
            border-color: #c9ddd4;
        }

        .field {
            display: grid;
            gap: 0.38rem;
            margin-bottom: 0.9rem;
        }

        .field label {
            font-size: 0.88rem;
            color: #32423d;
            font-weight: 500;
        }

        .input {
            width: 100%;
            border: 1px solid #cfded6;
            border-radius: 10px;
            background: #fff;
            color: var(--text);
            font-size: 0.95rem;
            padding: 0.62rem 0.72rem;
            outline: none;
            transition: border-color 0.16s ease, box-shadow 0.16s ease;
        }

        .input:focus {
            border-color: var(--nature-700);
            box-shadow: 0 0 0 4px rgba(35, 106, 84, 0.14);
        }

        .actions {
            margin-top: 1.1rem;
        }

        .btn-submit {
            width: 100%;
            border: 1px solid var(--nature-800);
            background: var(--nature-800);
            color: #fff;
            border-radius: 10px;
            padding: 0.65rem 0.95rem;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.16s ease, border-color 0.16s ease, transform 0.16s ease;
        }

        .btn-submit:hover {
            background: #174739;
            border-color: #174739;
            transform: translateY(-1px);
        }

        .login-link {
            color: var(--nature-800);
            text-decoration: none;
            font-weight: 600;
        }

        .login-link:hover {
            text-decoration: underline;
        }

        @media (max-width: 860px) {
            .login-shell {
                grid-template-columns: 1fr;
            }

            .login-aside {
                padding: 1.25rem 1.25rem 1.4rem;
            }

            .login-main {
                padding: 1.25rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="login-shell">
        <aside class="login-aside">
            <div>
                <div class="brand">CESIZen</div>
                <h2 class="aside-title">Espace utilisateur</h2>
                <p class="aside-copy">
                    Connecte-toi pour acceder a ton espace et gerer ton parcours bien-etre.
                </p>
            </div>
        </aside>

        <main class="login-main">
            <div class="login-card">
                <h1 class="login-title">Connexion</h1>
                <p class="login-subtitle">Entre ton email et ton mot de passe.</p>

                <form method="post">
                    {% if error %}
                        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}

                    {% if app.user %}
                        <div class="alert alert-info">
                            Tu es connecte en tant que {{ app.user.userIdentifier }},
                            <a class="login-link" href="{{ logout_path() }}">se deconnecter</a>.
                        </div>
                    {% endif %}

                    <div class="field">
                        <label for="username">Email</label>
                        <input
                            type="email"
                            value="{{ last_username }}"
                            name="_username"
                            id="username"
                            class="input"
                            autocomplete="email"
                            required
                            autofocus
                        >
                    </div>

                    <div class="field">
                        <label for="password">Mot de passe</label>
                        <input
                            type="password"
                            name="_password"
                            id="password"
                            class="input"
                            autocomplete="current-password"
                            required
                        >
                    </div>

                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                    <div class="actions">
                        <button class="btn-submit" type="submit">Se connecter</button>
                    </div>
                </form>
            </div>
        </main>
    </section>
{% endblock %}
