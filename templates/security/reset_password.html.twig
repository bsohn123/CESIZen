{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe | CESIZen{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/auth-login.css') }}">
{% endblock %}

{% block body %}
    <section class="site-shell site-shell--sm">
        {% include 'partials/_topbar.html.twig' %}

        <div class="login-shell" style="margin-top: 1rem;">
            <main class="login-main" style="width: 100%;">
                <div class="login-card">
                    <h1 class="login-title">Nouveau mot de passe</h1>
                    <p class="login-subtitle">Saisis et confirme ton nouveau mot de passe.</p>

                    {% if errors is defined and errors|length > 0 %}
                        <div class="alert alert-danger">
                            <ul style="margin: 0; padding-left: 1.2rem;">
                                {% for error in errors %}
                                    <li>{{ error }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    <form method="post">
                        <div class="field">
                            <label for="password">Nouveau mot de passe</label>
                            <input
                                type="password"
                                id="password"
                                name="password"
                                class="input"
                                minlength="8"
                                autocomplete="new-password"
                                required
                                autofocus
                            >
                        </div>

                        <div class="field">
                            <label for="password_confirm">Confirmer le mot de passe</label>
                            <input
                                type="password"
                                id="password_confirm"
                                name="password_confirm"
                                class="input"
                                minlength="8"
                                autocomplete="new-password"
                                required
                            >
                        </div>

                        <div class="actions">
                            <button class="btn-submit" type="submit">Enregistrer le mot de passe</button>
                        </div>

                        <p class="register-row">
                            <a class="register-link" href="{{ path('app_login') }}">Retour connexion</a>
                        </p>
                    </form>
                </div>
            </main>
        </div>
    </section>
{% endblock %}
