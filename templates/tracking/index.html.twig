{% extends 'base.html.twig' %}

{% block title %}Suivi personnel | CESIZen{% endblock %}

{% block stylesheets %}
<style>
@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

:root {
    --nature-950: #0b251d;
    --nature-900: #0f3328;
    --nature-800: #195241;
    --nature-700: #236a54;
    --text: #14231f;
    --muted: #5f6f69;
    --line: rgba(214, 228, 221, 0.9);
}

* { box-sizing: border-box; }

body {
    margin: 0;
    min-height: 100vh;
    font-family: "Manrope", sans-serif;
    color: var(--text);
    padding: 1.2rem;
    background:
        radial-gradient(circle at 15% 10%, rgba(35,106,84,0.12), transparent 40%),
        radial-gradient(circle at 85% 90%, rgba(15,51,40,0.08), transparent 40%),
        linear-gradient(160deg, rgba(247,251,249,0.9) 0%, rgba(238,245,242,0.88) 100%),
        url('{{ asset('images/login-bg.jpg') }}') center/cover no-repeat fixed;
}

.page-shell {
    width: min(1040px, 100%);
    margin: 0 auto;
    display: grid;
    gap: 1rem;
}

.topbar {
    background: rgba(255,255,255,0.84);
    border: 1px solid var(--line);
    border-radius: 14px;
    box-shadow: 0 16px 32px rgba(15, 51, 40, 0.08);
    padding: 0.55rem 0.75rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
}

.topbar-brand {
    text-decoration: none;
    color: var(--nature-950);
    font-weight: 900;
    font-size: 1rem;
}

.topbar-nav {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    flex-wrap: wrap;
}

.topbar-link {
    text-decoration: none;
    color: var(--nature-900);
    border-radius: 10px;
    border: 1px solid transparent;
    padding: 0.42rem 0.7rem;
    font-size: 0.86rem;
    font-weight: 800;
}

.topbar-link:hover {
    background: rgba(255,255,255,0.78);
    border-color: rgba(198, 220, 210, 0.85);
}

.topbar-link.is-active {
    background: rgba(35,106,84,0.1);
    border-color: rgba(35,106,84,0.2);
}

.card {
    background: rgba(255,255,255,0.85);
    border: 1px solid var(--line);
    border-radius: 18px;
    box-shadow: 0 20px 45px rgba(15, 51, 40, 0.08);
    padding: 1.2rem;
}

.kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
}

.kpi-title {
    margin: 0;
    color: var(--muted);
    font-size: 0.85rem;
    font-weight: 700;
}

.kpi-value {
    margin: 0.35rem 0 0;
    color: var(--nature-950);
    font-size: 1.65rem;
    font-weight: 900;
    letter-spacing: -0.02em;
}

.goal-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
}

.goal-title {
    margin: 0;
    color: var(--nature-950);
    font-size: 1.08rem;
    font-weight: 900;
}

.goal-meta {
    margin: 0;
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 700;
}

.goal-progress {
    margin-top: 0.7rem;
    height: 11px;
    border-radius: 999px;
    overflow: hidden;
    background: rgba(35,106,84,0.14);
    border: 1px solid rgba(35,106,84,0.2);
}

.goal-progress > span {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, #2f8a6f 0%, #7dc8a8 100%);
}

.goal-actions {
    margin-top: 0.9rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
}

.goal-note {
    margin: 0;
    color: #36544a;
    font-size: 0.9rem;
}

.btn {
    text-decoration: none;
    border-radius: 12px;
    border: 1px solid transparent;
    padding: 0.58rem 0.94rem;
    font-weight: 800;
    font-size: 0.88rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.btn-primary {
    color: #fff;
    background: linear-gradient(155deg, var(--nature-800), var(--nature-900));
    box-shadow: 0 12px 24px rgba(15, 51, 40, 0.18);
}

.btn-primary:hover {
    background: linear-gradient(155deg, #174739, #0f3328);
}

.content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem;
}

.section-title {
    margin: 0;
    color: var(--nature-950);
    font-size: 1.15rem;
    font-weight: 900;
}

.section-sub {
    margin: 0.35rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
}

.chart {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0.45rem;
    align-items: end;
    min-height: 160px;
}

.bar-item {
    display: grid;
    justify-items: center;
    gap: 0.35rem;
}

.bar-track {
    width: 100%;
    height: 120px;
    border-radius: 10px;
    border: 1px solid rgba(198,220,210,0.9);
    background: rgba(248,252,250,0.9);
    padding: 0.3rem;
    display: flex;
    align-items: flex-end;
}

.bar-fill {
    width: 100%;
    border-radius: 7px;
    background: linear-gradient(180deg, #66b391 0%, #236a54 100%);
    min-height: 0;
}

.bar-day {
    font-size: 0.78rem;
    color: #3d5b52;
    font-weight: 700;
}

.bar-count {
    font-size: 0.78rem;
    color: var(--nature-900);
    font-weight: 800;
}

.table-wrap {
    margin-top: 0.9rem;
    overflow-x: auto;
}

table {
    width: 100%;
    border-collapse: collapse;
    min-width: 520px;
}

th, td {
    text-align: left;
    padding: 0.62rem 0.55rem;
    border-bottom: 1px solid rgba(214,228,221,0.95);
    font-size: 0.88rem;
}

th {
    color: #3f5b52;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
}

td {
    color: var(--nature-900);
    font-weight: 700;
}

.empty {
    margin-top: 0.8rem;
    padding: 0.75rem;
    border: 1px dashed rgba(198,220,210,0.9);
    border-radius: 12px;
    color: var(--muted);
    font-size: 0.9rem;
}

.badge-grid {
    margin-top: 0.9rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.6rem;
}

.badge-item {
    border: 1px solid rgba(214,228,221,0.95);
    border-radius: 12px;
    background: rgba(255,255,255,0.82);
    padding: 0.7rem;
    display: grid;
    gap: 0.24rem;
}

.badge-item.is-unlocked {
    border-color: rgba(35,106,84,0.45);
    background: rgba(228,246,238,0.82);
}

.badge-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
}

.badge-title {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--nature-950);
}

.badge-progress,
.badge-state {
    margin: 0;
    font-size: 0.78rem;
    color: #3e5951;
    font-weight: 700;
}

@media (max-width: 980px) {
    .kpi-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .content-grid { grid-template-columns: 1fr; }
}

@media (max-width: 680px) {
    body { padding: 0.9rem; }
    .topbar { flex-wrap: wrap; }
    .topbar-nav { width: 100%; }
    .kpi-grid { grid-template-columns: 1fr; }
    .badge-grid { grid-template-columns: 1fr; }
}
</style>
{% endblock %}

{% block body %}
<main class="page-shell">
    {% include 'partials/_site_nav.html.twig' with { active_route: 'app_personal_tracking' } %}
    <nav class="topbar" aria-label="Navigation suivi" hidden>
        <a class="topbar-brand" href="{{ path('app_home') }}">CESIZen</a>
        <div class="topbar-nav">
            <a class="topbar-link" href="{{ path('app_home') }}">Accueil</a>
            <a class="topbar-link" href="{{ path('app_breathing_guided') }}">Respiration guid&eacute;e</a>
            <a class="topbar-link is-active" href="{{ path('app_personal_tracking') }}" aria-current="page">Suivi personnel</a>
            <a class="topbar-link" href="{{ path('app_profile') }}">Mon profil</a>
        </div>
    </nav>

    <section class="kpi-grid">
        <article class="card">
            <p class="kpi-title">Sessions totales</p>
            <p class="kpi-value">{{ total_sessions }}</p>
        </article>
        <article class="card">
            <p class="kpi-title">Sessions cette semaine</p>
            <p class="kpi-value">{{ week_total_sessions }}</p>
        </article>
        <article class="card">
            <p class="kpi-title">Streak actuel</p>
            <p class="kpi-value">{{ streak_days }} j</p>
        </article>
        <article class="card">
            <p class="kpi-title">Temps total respir&eacute;</p>
            <p class="kpi-value">{{ total_duration_label }}</p>
        </article>
    </section>

    <section class="card">
        <div class="goal-head">
            <p class="goal-title">Objectif du jour</p>
            <p class="goal-meta">{{ daily_goal_done }}/{{ daily_goal_target }} session</p>
        </div>
        <div class="goal-progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{ daily_goal_percent }}" aria-label="Progression de l objectif quotidien">
            <span style="width: {{ daily_goal_percent }}%;"></span>
        </div>
        <div class="goal-actions">
            <p class="goal-note">
                {% if daily_goal_done >= daily_goal_target %}
                    Objectif atteint, bravo.
                {% else %}
                    Encore {{ daily_goal_target - daily_goal_done }} session pour valider ta journ&eacute;e.
                {% endif %}
            </p>
            <a class="btn btn-primary" href="{{ path('app_breathing_guided') }}">Lancer une session</a>
        </div>
    </section>

    <section class="content-grid">
        <article class="card">
            <h2 class="section-title">Graphique 7 jours</h2>
            <p class="section-sub">Nombre de sessions r&eacute;alis&eacute;es chaque jour.</p>

            <div class="chart" aria-label="Histogramme des sessions sur 7 jours">
                {% for point in weekly_series %}
                    {% set height = weekly_max > 0 ? ((point.count / weekly_max) * 100)|round(0, 'floor') : 0 %}
                    <div class="bar-item">
                        <div class="bar-track">
                            <span class="bar-fill" style="height: {{ height }}%;"></span>
                        </div>
                        <span class="bar-day">{{ point.label }}</span>
                        <span class="bar-count">{{ point.count }}</span>
                    </div>
                {% endfor %}
            </div>
        </article>

        <article class="card">
            <h2 class="section-title">Badges</h2>
            <p class="section-sub">D&eacute;bloque-les au fil de ta pratique.</p>

            <div class="badge-grid">
                {% for milestone in milestones %}
                    <div class="badge-item {{ milestone.unlocked ? 'is-unlocked' : '' }}">
                        <div class="badge-top">
                            <p class="badge-title">{{ milestone.label == '1ere session' ? '1&egrave;re session' : milestone.label }}</p>
                            <span aria-hidden="true">{{ milestone.unlocked ? '&#10003;' : '&#128274;' }}</span>
                        </div>
                        <p class="badge-progress">{{ milestone.progress }}/{{ milestone.target }}</p>
                        <p class="badge-state">{{ milestone.unlocked ? 'D&eacute;bloqu&eacute;' : 'Verrouill&eacute;' }}</p>
                    </div>
                {% endfor %}
            </div>
        </article>
    </section>

    <section class="card">
        <h2 class="section-title">Historique r&eacute;cent</h2>
        <p class="section-sub">Tes derni&egrave;res sessions de respiration.</p>

        {% if recent_launches is not empty %}
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Exercice</th>
                            <th>Cycles</th>
                            <th>Dur&eacute;e</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for launch in recent_launches %}
                            <tr>
                                <td>{{ launch.launchDate ? launch.launchDate|date('d/m/Y H:i') : 'N/A' }}</td>
                                <td>{{ launch.breathingExercise ? launch.breathingExercise.name : 'Exercice' }}</td>
                                <td>{{ launch.cycleCount }}</td>
                                <td>{{ launch.totalDuration ? launch.totalDuration|date('H:i:s') : '00:00:00' }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <p class="empty">Aucune session enregistr&eacute;e pour le moment.</p>
        {% endif %}
    </section>
</main>
{% endblock %}




