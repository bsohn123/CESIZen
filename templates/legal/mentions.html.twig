{% extends 'base.html.twig' %}

{% block title %}Mentions l&eacute;gales | CESIZen{% endblock %}

{% block stylesheets %}
    <style>
        :root {
            --nature-900: #0f3328;
            --nature-800: #195241;
            --line: #d6e4dd;
            --text: #1e2a26;
            --muted: #5c6b66;
            --surface: #f4faf7;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Manrope", "Segoe UI", Arial, sans-serif;
            color: var(--text);
            background:
                linear-gradient(160deg, rgba(238,247,242,0.86) 0%, rgba(229,240,234,0.82) 100%),
                url('{{ asset('images/login-bg.jpg') }}') center/cover no-repeat;
            padding: 1.25rem;
        }
        .card { width: min(860px, 100%); background: #fff; border: 1px solid var(--line); border-radius: 16px; box-shadow: 0 18px 48px rgba(16,44,35,0.12); overflow: hidden; }
        .head { padding: 1.35rem 1.4rem; background: linear-gradient(165deg, var(--nature-900), var(--nature-800)); color: #fff; }
        .head h1 { margin: 0; font-size: 1.35rem; font-weight: 800; }
        .head p { margin: 0.35rem 0 0; color: rgba(255,255,255,0.86); font-size: 0.92rem; }
        .content { padding: 1.25rem 1.35rem; background: var(--surface); display: grid; gap: 0.8rem; }
        .section { border: 1px solid var(--line); border-radius: 12px; background: #fff; padding: 1rem 1.05rem; }
        .section h2 { margin: 0 0 0.4rem; font-size: 1rem; color: var(--nature-900); }
        .section p { margin: 0; color: var(--muted); line-height: 1.55; font-size: 0.93rem; }
        .section p + p { margin-top: 0.7rem; }
        .foot { padding: 0 1.35rem 1.2rem; background: var(--surface); display: flex; gap: 0.6rem; flex-wrap: wrap; }
        .btn { border-radius: 10px; padding: 0.62rem 0.9rem; border: 1px solid transparent; font-size: 0.9rem; font-weight: 600; text-decoration: none; }
        .btn-secondary { background: #fff; border-color: #cfded6; color: #355048; }
        .btn-secondary:hover { background: #f6fbf8; }
    </style>
{% endblock %}

{% block body %}
    <section class="site-shell site-shell--sm">
        {% include 'partials/_topbar.html.twig' %}

        <div class="card">
            <header class="head">
                <h1>Mentions l&eacute;gales &mdash; CESIZen</h1>
                <p>Informations l&eacute;gales relatives &agrave; l&rsquo;application.</p>
            </header>

            <main class="content">
                <article class="section">
                    <h2>1. &Eacute;diteur</h2>
                    <p>L&rsquo;application CESIZen est un projet scolaire d&eacute;velopp&eacute; dans le cadre d&rsquo;une formation au CESI.</p>
                    <p>Il s&rsquo;agit d&rsquo;un projet &agrave; vocation p&eacute;dagogique et non commerciale.</p>
                </article>

                <article class="section">
                    <h2>2. H&eacute;bergement</h2>
                    <p>L&rsquo;application est h&eacute;berg&eacute;e dans un environnement de d&eacute;veloppement local &agrave; des fins de d&eacute;monstration scolaire.</p>
                </article>

                <article class="section">
                    <h2>3. Propri&eacute;t&eacute; intellectuelle</h2>
                    <p>L&rsquo;ensemble des contenus pr&eacute;sents sur CESIZen (textes, design, structure) sont prot&eacute;g&eacute;s par le droit d&rsquo;auteur.</p>
                    <p>Toute reproduction ou utilisation non autoris&eacute;e est interdite.</p>
                </article>

                <article class="section">
                    <h2>4. Responsabilit&eacute;</h2>
                    <p>CESIZen propose des exercices de respiration &agrave; vocation informative et de bien-&ecirc;tre uniquement. L&rsquo;application ne constitue pas un avis m&eacute;dical.</p>
                </article>
            </main>

            <footer class="foot">
                <a class="btn btn-secondary" href="{{ path('app_home') }}">Retour &agrave; l&rsquo;accueil</a>
            </footer>
        </div>
    </section>
{% endblock %}
