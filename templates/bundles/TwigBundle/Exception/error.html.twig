{% extends 'base.html.twig' %}

{% block title %}Erreur {{ status_code }} | CESIZen{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .error-shell {
            width: min(600px, 100%);
            margin: 0 auto;
            padding: 1.2rem;
            display: grid;
            gap: 1rem;
        }

        .error-card {
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid rgba(214, 228, 221, 0.85);
            border-radius: 20px;
            box-shadow: 0 24px 56px rgba(15, 51, 40, 0.10);
            padding: 3rem 2.4rem;
            text-align: center;
            backdrop-filter: blur(10px);
        }

        .error-code {
            font-size: clamp(4rem, 14vw, 7rem);
            font-weight: 900;
            color: rgba(25, 82, 65, 0.18);
            letter-spacing: -0.04em;
            margin: 0;
            line-height: 1;
        }

        .error-title {
            margin: 0.6rem 0 0;
            font-size: 1.4rem;
            font-weight: 800;
            color: #0f3328;
        }

        .error-text {
            margin: 0.6rem 0 2rem;
            color: #5f6f69;
            font-size: 0.97rem;
            line-height: 1.6;
        }

        .error-actions {
            display: flex;
            gap: 0.8rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-home {
            display: inline-flex;
            align-items: center;
            padding: 0.7rem 1.4rem;
            border-radius: 14px;
            font-weight: 800;
            font-size: 0.92rem;
            text-decoration: none;
            transition: all 0.15s ease;
        }

        .btn-home--primary {
            background: linear-gradient(155deg, #195241, #0f3328);
            color: #fff;
            border: 1px solid rgba(15, 51, 40, 0.2);
        }

        .btn-home--primary:hover {
            background: linear-gradient(155deg, #174739, #0b2920);
        }
    </style>
{% endblock %}

{% block body %}
    <div class="error-shell">
        {% include 'partials/_topbar.html.twig' %}

        <div class="error-card">
            <p class="error-code">{{ status_code }}</p>
            <h1 class="error-title">
                {% if status_code == 403 %}Accès refusé
                {% elseif status_code == 500 %}Erreur serveur
                {% else %}Une erreur est survenue
                {% endif %}
            </h1>
            <p class="error-text">
                {% if status_code == 403 %}
                    Tu n'as pas les droits pour accéder à cette page.
                {% elseif status_code == 500 %}
                    Une erreur inattendue s'est produite. Réessaie dans quelques instants.
                {% else %}
                    Quelque chose s'est mal passé. Retourne à l'accueil.
                {% endif %}
            </p>
            <div class="error-actions">
                <a class="btn-home btn-home--primary" href="{{ path('app_home') }}">Retour à l'accueil</a>
            </div>
        </div>
    </div>
{% endblock %}
