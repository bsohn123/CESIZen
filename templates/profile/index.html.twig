{% extends 'base.html.twig' %}

{% block title %}Mon profil | CESIZen{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/profile.css') }}">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('scripts/profile.js') }}" defer></script>
{% endblock %}

{% block body %}
    {% set panel = active_panel|default('') %}

    <section class="page">
        {% include 'partials/_site_nav.html.twig' with { active_route: 'app_profile' } %}

        <div class="flash-stack" aria-live="polite" aria-atomic="true">
            {% for message in app.flashes('success') %}
                <div class="flash flash-success">
                    <span class="flash-prefix">Succès :</span>{{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('warning') %}
                <div class="flash flash-warning">
                    <span class="flash-prefix">Attention :</span>{{ message }}
                </div>
            {% endfor %}
        </div>

        {% set avatar_src = profile_user.imageName ? asset('uploads/profile/' ~ profile_user.imageName) : asset('images/avatar-default.svg') %}

        <article class="card hero">
            <div class="hero-left">
                <div class="avatar-wrap">
                    <div class="avatar">
                        <img src="{{ avatar_src }}" alt="Photo de profil">
                    </div>

                    <form method="post" action="{{ path('app_profile_photo') }}" enctype="multipart/form-data" class="avatar-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('profile_photo') }}">
                        <input
                            type="file"
                            id="profile_photo"
                            name="profile_photo"
                            class="avatar-input"
                            accept=".jpg,.jpeg,.png,.gif,.webp"
                            onchange="if (this.files.length) { this.form.submit(); }"
                        >
                        <label class="btn btn-outline-neutral btn-compact" for="profile_photo">Modifier la photo</label>
                        <p class="helper">JPG, PNG, GIF, WebP - 5 Mo max</p>
                    </form>
                </div>

                <div class="identity">
                    {% set is_admin_account = 'ROLE_ADMIN' in profile_user.roles %}
                    <h1>
                        {{ profile_user.username }}
                        <span class="verify-badge">
                            {{ is_admin_account ? 'Compte administrateur' : 'Compte utilisateur' }}
                        </span>
                    </h1>

                    <div class="meta-row">
                        <span>{{ profile_user.username }}</span>
                        <span>{{ profile_user.email }}</span>
                    </div>

                    <div class="chips">
                        <span class="chip">Créé le {{ profile_user.createdAt ? profile_user.createdAt|date('d/m/Y') : 'N/A' }}</span>
                    </div>
                </div>
            </div>

            <div class="hero-actions">
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin') }}" class="btn btn-outline-success">Accéder au dashboard</a>
                {% endif %}
                <button type="button" class="btn btn-outline-neutral" id="open-password-panel">Changer le mot de passe</button>
                <a href="{{ path('app_logout') }}" class="btn btn-ghost">Déconnexion</a>
            </div>
        </article>

        <article class="card infos">
            <header class="infos-head">
                <div>
                    <h2 class="infos-title">Informations</h2>
                    <p class="infos-sub">Données de votre compte</p>
                </div>
                <button type="button" class="btn btn-outline-neutral" id="open-edit-panel">Modifier</button>
            </header>

            <div class="grid">
                <div class="field">
                    <p class="field-label">
                        <span class="field-icon" aria-hidden="true">✉</span>
                        <span>Email</span>
                    </p>
                    <p class="field-value">{{ profile_user.email }}</p>
                </div>

                <div class="field">
                    <p class="field-label">
                        <span class="field-icon" aria-hidden="true">👤</span>
                        <span>Username</span>
                    </p>
                    <p class="field-value">{{ profile_user.username }}</p>
                </div>

                <div class="field">
                    <p class="field-label">
                        <span class="field-icon" aria-hidden="true">📅</span>
                        <span>Date de création</span>
                    </p>
                    <p class="field-value">{{ profile_user.createdAt ? profile_user.createdAt|date('d/m/Y à H:i') : 'Non disponible' }}</p>
                </div>

                <div class="field">
                    <p class="field-label">
                        <span class="field-icon" aria-hidden="true">🕒</span>
                        <span>Dernière connexion</span>
                    </p>
                    <p class="field-value">{{ profile_user.lastLoginAt ? profile_user.lastLoginAt|date('d/m/Y à H:i') : 'Jamais' }}</p>
                </div>

                <div class="field field-wide">
                    <p class="field-label">
                        <span class="field-icon" aria-hidden="true">🛡</span>
                        <span>Rôles</span>
                    </p>
                    <div class="roles">
                        {% for role in profile_user.roles %}
                            <span class="role">{{ role }}</span>
                        {% else %}
                            <span class="role">ROLE_USER</span>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </article>

        <article class="card panel" id="edit-panel" {% if panel != 'edit' %}hidden{% endif %}>
            <h3>Modifier mes informations</h3>
            <p>Mets à jour ton pseudo et ton email.</p>

            <form method="post" action="{{ path('app_profile_edit') }}" class="form-grid">
                <input type="hidden" name="_token" value="{{ csrf_token('profile_edit') }}">

                <div class="form-field">
                    <label for="edit_email">Email</label>
                    <input type="email" id="edit_email" name="email" value="{{ profile_user.email }}" required>
                </div>

                <div class="form-field">
                    <label for="edit_username">Username</label>
                    <input type="text" id="edit_username" name="username" value="{{ profile_user.username }}" minlength="3" required>
                </div>

                <div class="panel-actions">
                    <button type="submit" class="btn btn-dark">Enregistrer</button>
                    <button type="button" class="btn btn-outline-neutral" data-close-panel="edit-panel">Annuler</button>
                </div>
            </form>
        </article>

        <article class="card panel" id="password-panel" {% if panel != 'password' %}hidden{% endif %}>
            <h3>Changer mon mot de passe</h3>
            <p>Renseigne ton mot de passe actuel puis le nouveau.</p>

            <form method="post" action="{{ path('app_profile_change_password') }}" class="form-grid">
                <input type="hidden" name="_token" value="{{ csrf_token('profile_change_password') }}">

                <div class="form-field">
                    <label for="current_password">Mot de passe actuel</label>
                    <input type="password" id="current_password" name="current_password" required>
                </div>

                <div class="form-field">
                    <label for="new_password">Nouveau mot de passe</label>
                    <input type="password" id="new_password" name="new_password" minlength="8" required>
                </div>

                <div class="form-field">
                    <label for="confirm_password">Confirmer le nouveau mot de passe</label>
                    <input type="password" id="confirm_password" name="confirm_password" minlength="8" required>
                </div>

                <div class="panel-actions">
                    <button type="submit" class="btn btn-dark">Mettre à jour</button>
                    <button type="button" class="btn btn-outline-neutral" data-close-panel="password-panel">Annuler</button>
                </div>
            </form>
        </article>

        <article class="card danger-zone">
            <h3>Zone sensible</h3>
            <p>La suppression est définitive et entraîne la perte de vos données associées.</p>
            <form method="post" action="{{ path('app_profile_delete') }}" onsubmit="return confirm('Confirmer la suppression définitive de votre compte ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('profile_delete') }}">
                <button type="submit" class="btn btn-danger">Supprimer mon compte</button>
            </form>
        </article>
    </section>
{% endblock %}
