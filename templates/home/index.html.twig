{% extends 'base.html.twig' %}

{% block title %}Accueil | CESIZen{% endblock %}

{% block stylesheets %}
<style>
@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

:root {
    --nature-950: #0b251d;
    --nature-900: #0f3328;
    --nature-800: #195241;
    --nature-700: #236a54;

    --text: #14231f;
    --muted: #5f6f69;

    --line: rgba(214, 228, 221, 0.85);
}

/* Base */
* { box-sizing: border-box; }

body {
    margin: 0;
    min-height: 100vh;
    font-family: "Manrope", sans-serif;
    color: var(--text);
    padding: 1.2rem;

    background:
        radial-gradient(circle at 15% 10%, rgba(35,106,84,0.12), transparent 40%),
        radial-gradient(circle at 85% 90%, rgba(15,51,40,0.08), transparent 40%),
        linear-gradient(160deg, #f7fbf9 0%, #eef5f2 100%);
}

/* Layout */
.page-shell {
    width: min(980px, 100%);
    margin: 0 auto;
    display: grid;
    gap: 1rem;
    position: relative;
    isolation: isolate;
}

/* ===================== */
/* Top Menu (improved)   */
/* ===================== */
.topbar {
    background: rgba(255,255,255,0.82);
    border: 1px solid var(--line);
    border-radius: 14px;
    box-shadow: 0 16px 32px rgba(15, 51, 40, 0.08);
    padding: 0.55rem 0.75rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    position: relative;
    z-index: 120;
    overflow: visible;
}

.topbar-brand {
    text-decoration: none;
    color: var(--nature-950);
    font-weight: 900;
    font-size: 1rem;
    letter-spacing: 0.01em;
    padding: 0.35rem 0.4rem;
    border-radius: 10px;
}

.topbar-brand:hover {
    background: rgba(255,255,255,0.7);
}

.topbar-nav {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
    overflow: visible;
}

/* Liens "premium" : plus proches d'onglets que de boutons */
.topbar-link {
    text-decoration: none;
    color: var(--nature-900);
    border: 1px solid transparent;
    background: transparent;
    border-radius: 12px;
    padding: 0.45rem 0.7rem;
    font-size: 0.88rem;
    font-weight: 800;
    min-height: 36px;
    display: inline-flex;
    align-items: center;
    transition: background .15s ease, border-color .15s ease, transform .15s ease;
}

.topbar-link:hover {
    background: rgba(255,255,255,0.75);
    border-color: rgba(198, 220, 210, 0.75);
    transform: translateY(-1px);
}

/* Lien actif (tu peux aussi gérer via une variable Twig si tu veux) */
.topbar-link.is-active {
    background: rgba(35,106,84,0.10);
    border-color: rgba(35,106,84,0.18);
}

/* CTA principal : uniquement "Créer un compte" quand non connecté */
.topbar-link-primary {
    color: #fff;
    border-color: rgba(15, 51, 40, 0.2);
    background: linear-gradient(155deg, var(--nature-800), var(--nature-900));
    box-shadow: 0 10px 18px rgba(15, 51, 40, 0.14);
}

.topbar-link-primary:hover {
    background: linear-gradient(155deg, #174739, #0f3328);
    border-color: rgba(15, 51, 40, 0.25);
}

/* Bouton léger (ex: Se connecter) */
.topbar-link-soft {
    background: rgba(255,255,255,0.62);
    border-color: rgba(198, 220, 210, 0.9);
    border: 1px solid rgba(198, 220, 210, 0.9);
}

.topbar-link-soft:hover{
    background: rgba(255,255,255,0.85);
}

/* ====== Menus dynamiques (dropdown) ====== */
.menu-group {
    position: relative;
    display: inline-flex;
    align-items: center;
    z-index: 125;
}

.menu-trigger {
    border: 1px solid transparent;
    background: transparent;
    cursor: pointer;
    user-select: none;
    gap: 0.4rem;
}

.menu-trigger:focus-visible {
    outline: 2px solid #195241;
    outline-offset: 2px;
}

.menu-chevron {
    font-size: 0.84rem;
    opacity: 0.75;
}

.menu-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 0.35rem;
    min-width: 230px;
    background: rgba(255,255,255,0.95);
    border: 1px solid rgba(214, 228, 221, 0.95);
    border-radius: 14px;
    box-shadow: 0 18px 45px rgba(15, 51, 40, 0.12);
    padding: 0.35rem;
    display: none;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    z-index: 195;
}

.menu-group:hover .menu-dropdown,
.menu-group:focus-within .menu-dropdown {
    display: block;
}

.menu-page-link {
    display: block;
    padding: 0.5rem 0.62rem;
    border-radius: 10px;
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--nature-900);
    border: 1px solid transparent;
}

.menu-page-link:hover {
    background: rgba(35,106,84,0.08);
    border-color: rgba(35,106,84,0.14);
}

/* ====== Menu utilisateur (dropdown CSS only) ====== */
.user-menu {
    position: relative;
    display: inline-flex;
    align-items: center;
    z-index: 130;
}

.user-trigger {
    border: 1px solid transparent;
    background: transparent;
    cursor: pointer;
    user-select: none;
    gap: 0.55rem;
}

.user-trigger:focus-visible {
    outline: 2px solid #195241;
    outline-offset: 2px;
}

.user-avatar {
    width: 28px;
    height: 28px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(35,106,84,0.10);
    border: 1px solid rgba(35,106,84,0.18);
    color: var(--nature-900);
    font-weight: 900;
    font-size: 0.82rem;
}

.user-chevron {
    font-size: 0.9rem;
    opacity: 0.75;
}

/* Cache le dropdown par défaut */
.user-dropdown {
    position: absolute;
    top: 100%;
    margin-top: 0.35rem;
    right: 0;
    width: 220px;
    background: rgba(255,255,255,0.92);
    border: 1px solid rgba(214, 228, 221, 0.9);
    border-radius: 14px;
    box-shadow: 0 18px 45px rgba(15, 51, 40, 0.12);
    padding: 0.35rem;
    display: none;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    z-index: 200;
}

.user-menu:focus-within .user-dropdown,
.user-menu:hover .user-dropdown {
    display: block;
}

.user-item {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .5rem;
    padding: 0.55rem 0.65rem;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 800;
    font-size: 0.9rem;
    color: var(--nature-900);
    border: 1px solid transparent;
    background: transparent;
}

.user-item:hover {
    background: rgba(35,106,84,0.08);
    border-color: rgba(35,106,84,0.14);
}

/* Déconnexion discrète */
.user-item.logout {
    color: #1a2c26;
    opacity: 0.9;
}

.user-item.logout:hover {
    background: rgba(15,51,40,0.06);
    border-color: rgba(15,51,40,0.10);
}

/* HERO Premium */
.hero-shell {
    background: rgba(255,255,255,0.82);
    border: 1px solid var(--line);
    border-radius: 20px;
    box-shadow: 0 30px 70px rgba(15, 51, 40, 0.10);
    padding: 2.2rem 2rem;
    backdrop-filter: blur(10px) saturate(1.05);
    -webkit-backdrop-filter: blur(10px) saturate(1.05);
    position: relative;
    z-index: 1;
    overflow: visible;
}

.hero-layout {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 1.2rem;
    align-items: center;
}

.hero-title {
    margin: 0;
    font-size: clamp(2rem, 3.2vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--nature-950);
}

.hero-subtitle {
    margin: 0.8rem 0 0;
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 60ch;
    color: var(--muted);
}

.hero-actions {
    margin-top: 1.4rem;
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
}

.hero-brand img {
    width: min(100%, 340px);
    filter: drop-shadow(0 18px 30px rgba(15, 51, 40, 0.18));
}

/* Boutons Premium */
.btn {
    border-radius: 16px;
    padding: .8rem 1.2rem;
    font-weight: 800;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    transition: all .2s ease;
}

.btn-primary {
    background: linear-gradient(155deg, var(--nature-800), var(--nature-900));
    color: #fff;
    box-shadow: 0 18px 34px rgba(15, 51, 40, 0.20);
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 44px rgba(15, 51, 40, 0.25);
}

.btn-secondary {
    background: rgba(255,255,255,0.7);
    border: 1px solid rgba(198, 220, 210, 0.9);
    color: var(--nature-900);
}

.btn-secondary:hover {
    background: rgba(255,255,255,0.9);
    transform: translateY(-2px);
}

/* FEATURES Premium */
.features {
    background: rgba(255,255,255,0.82);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 1.5rem;
    box-shadow: 0 24px 60px rgba(15, 51, 40, 0.08);
    backdrop-filter: blur(8px);
}

.features-title {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--nature-950);
}

.features-grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.9rem;
}

.feature-card {
    background: rgba(255,255,255,0.9);
    border: 1px solid rgba(215, 229, 222, 0.95);
    border-radius: 16px;
    padding: 1rem;
    box-shadow: 0 14px 30px rgba(15, 51, 40, 0.06);
    transition: all .2s ease;
}

.feature-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 44px rgba(15, 51, 40, 0.12);
}

.feature-card h3 {
    margin: 0;
    font-weight: 800;
    color: var(--nature-950);
}

.feature-card p {
    margin-top: .5rem;
    font-size: .95rem;
    color: var(--muted);
}

.feature-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
}

.feature-card-link:focus-visible {
    outline: 3px solid #195241;
    outline-offset: 3px;
    border-radius: 16px;
}

.feature-link {
    margin-top: 0.75rem;
    display: inline-flex;
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 800;
    color: var(--nature-900);
    border-bottom: 1px solid rgba(35,106,84,0.26);
}

.feature-link:hover {
    color: var(--nature-700);
    border-bottom-color: rgba(35,106,84,0.45);
}

/* RESOURCES Premium */
.resources {
    background: rgba(255,255,255,0.82);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 1.5rem;
    box-shadow: 0 24px 60px rgba(15, 51, 40, 0.08);
    backdrop-filter: blur(8px);
}

.resources-title {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--nature-950);
}

.resources-grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.9rem;
}

.resource-card {
    background: rgba(255,255,255,0.9);
    border: 1px solid rgba(215, 229, 222, 0.95);
    border-radius: 16px;
    padding: 1rem;
    box-shadow: 0 14px 30px rgba(15, 51, 40, 0.06);
    transition: all .2s ease;
}

.resource-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 44px rgba(15, 51, 40, 0.12);
}

.resource-meta {
    display: inline-flex;
    align-items: center;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--nature-800);
    background: rgba(35,106,84,0.10);
    border: 1px solid rgba(35,106,84,0.18);
    border-radius: 999px;
    padding: 0.18rem 0.55rem;
}

.resource-card h3 {
    margin: 0.65rem 0 0;
    font-weight: 800;
    color: var(--nature-950);
}

.resource-card p {
    margin: 0.55rem 0 0;
    font-size: .95rem;
    color: var(--muted);
}

.resource-link {
    margin-top: 0.9rem;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    font-weight: 800;
    font-size: 0.9rem;
    color: var(--nature-900);
    border-bottom: 1px solid rgba(35,106,84,0.26);
}

.resource-link:hover {
    color: var(--nature-700);
    border-bottom-color: rgba(35,106,84,0.45);
}

/* CTA Premium */
.cta {
    border-radius: 20px;
    background: linear-gradient(155deg, rgba(9,33,26,0.95), rgba(25,82,65,0.92));
    padding: 1.5rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    color: #fff;
    box-shadow: 0 28px 65px rgba(15, 51, 40, 0.22);
}

.cta p {
    margin: 0;
    font-size: 1rem;
}

.btn-cta {
    background: #fff;
    color: var(--nature-950);
    font-weight: 800;
    border-radius: 16px;
    padding: .8rem 1.3rem;
    box-shadow: 0 14px 28px rgba(0,0,0,0.12);
}

.btn-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 36px rgba(0,0,0,0.18);
}

/* Responsive */
@media (max-width: 860px) {
    .hero-layout { grid-template-columns: 1fr; }
    .features-grid { grid-template-columns: 1fr; }
    .resources-grid { grid-template-columns: 1fr; }
    .topbar { padding: 0.58rem 0.65rem; }
    .user-dropdown { width: 210px; }
}
</style>
{% endblock %}

{% block body %}
<main class="page-shell">
    <nav class="topbar" aria-label="Menu principal">
        <a class="topbar-brand" href="{{ path('app_home') }}">CESIZen</a>

        <div class="topbar-nav">
            <a class="topbar-link is-active" href="{{ path('app_home') }}">Accueil</a>
            <a class="topbar-link" href="{{ path('app_breathing_guided') }}">Respiration guidee</a>

            {% for menu in menus %}
                {% set pages = menu.pages %}
                {% if pages|length > 0 %}
                    <div class="menu-group">
                        <button class="topbar-link menu-trigger" type="button" aria-haspopup="true">
                            <span>{{ menu.title }}</span>
                            <span class="menu-chevron">&#9662;</span>
                        </button>
                        <div class="menu-dropdown" role="menu" aria-label="Pages de {{ menu.title }}">
                            {% for page in pages %}
                                <a class="menu-page-link" href="{{ path('app_page_show', { slug: page.slug }) }}">{{ page.title }}</a>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            {% endfor %}

            {% if app.user %}
                {# Menu utilisateur (profil + déconnexion) #}
                <div class="user-menu">
                    <button class="topbar-link user-trigger" type="button" aria-haspopup="true">
                        <span class="user-avatar">
                            {{ app.user.userIdentifier|default('U')|slice(0,1)|upper }}
                        </span>
                        <span>Compte</span>
                        <span class="user-chevron">&#9662;</span>
                    </button>

                    <div class="user-dropdown" role="menu" aria-label="Menu compte">
                        <a class="user-item" href="{{ path('app_profile') }}">Mon profil</a>
                        <a class="user-item logout" href="{{ path('app_logout') }}">Déconnexion</a>
                    </div>
                </div>
            {% else %}
                <a class="topbar-link topbar-link-soft" href="{{ path('app_login') }}">Se connecter</a>
                <a class="topbar-link topbar-link-primary" href="{{ path('app_register') }}">Créer un compte</a>
            {% endif %}
        </div>
    </nav>

    <section class="hero-shell">
        <div class="hero-layout">
            <div>
                <h1 class="hero-title">Retrouve le calme. Respire. Reprends le contrôle.</h1>
                <p class="hero-subtitle">
                    Une application moderne et simple pour réduire ton stress et améliorer ta concentration au quotidien.
                </p>
                <div class="hero-actions">
                    <a class="btn btn-primary" href="{{ path('app_register') }}">Commencer gratuitement</a>
                    <a class="btn btn-secondary" href="{{ path('app_login') }}">Se connecter</a>
                </div>
            </div>
            <div class="hero-brand">
                <img src="{{ asset('images/meditation2.png') }}" alt="Logo CESIZen">
            </div>
        </div>
    </section>

    <section class="features">
        <h2 class="features-title">Fonctionnalites</h2>
        <div class="features-grid">
            <a class="feature-card feature-card-link" href="{{ path('app_breathing_guided') }}">
                <h3>Respiration guidee</h3>
                <p>Des exercices simples pour retrouver le calme et la concentration.</p>
            </a>
            <a class="feature-card feature-card-link" href="{{ app.user ? path('app_profile') : path('app_login') }}">
                <h3>Suivi personnel</h3>
                <p>Observe ton evolution et construis une routine durable.</p>
            </a>
            <a class="feature-card feature-card-link" href="{{ resources is not empty ? path('app_page_show', { slug: (resources|first).slug }) : '#resources-section' }}">
                <h3>Ressources bien-etre</h3>
                <p>Des contenus utiles pour mieux comprendre et gerer ton stress.</p>
            </a>
        </div>
    </section>

    <section class="resources" id="resources-section">
        <h2 class="resources-title">Ressources bien-etre</h2>
        <div class="resources-grid">
            {% if resources is not empty %}
                {% for page in resources %}
                    <article class="resource-card">
                        <span class="resource-meta">
                            {{ page.menu ? page.menu.title : 'Article' }}{% if page.createdAt %} - {{ page.createdAt|date('d/m/Y') }}{% endif %}
                        </span>
                        <h3>{{ page.title }}</h3>
                        <p>{{ page.content|striptags|slice(0, 140) }}{% if page.content|striptags|length > 140 %}...{% endif %}</p>
                        <a class="resource-link" href="{{ path('app_page_show', { slug: page.slug }) }}">Lire</a>
                    </article>
                {% endfor %}
            {% else %}
                <article class="resource-card">
                    <span class="resource-meta">Article</span>
                    <h3>Bientot des ressources bien-etre</h3>
                    <p>Ajoute des pages publiees dans ton dashboard pour les afficher ici automatiquement.</p>
                </article>
            {% endif %}
        </div>
    </section>

    <section class="cta">
        <p>Prêt à te sentir plus serein dès aujourd’hui ?</p>
        <a class="btn btn-cta" href="{{ path('app_register') }}">Créer mon compte</a>
    </section>
</main>
{% endblock %}



